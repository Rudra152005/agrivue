# ============================================================
# AgriVue / Agri-TrekOps — Root .gitignore
# Covers: Node.js, Vite/React, MongoDB, Docker, Jenkins,
#         SonarQube, Nexus, Grafana, and editor/OS files
# ============================================================


# ────────────────────────────────────────────────────────────
# Node.js — Frontend & Backend
# ────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/
.pnp.*
package-lock.json
bun.lock

# ────────────────────────────────────────────────────────────
# Environment & Secrets — NEVER commit these
# ────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
backend/.env
devops/.env

# ────────────────────────────────────────────────────────────
# Vite / React Frontend Build Output
# ────────────────────────────────────────────────────────────
Frontend/dist/
Frontend/.tanstack/
Frontend/.lovable/
Frontend/build/
dist/
build/

# ────────────────────────────────────────────────────────────
# TypeScript
# ────────────────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ────────────────────────────────────────────────────────────
# Test & Coverage Reports
# ────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ────────────────────────────────────────────────────────────
# Logs
# ────────────────────────────────────────────────────────────
logs/
*.log
*.log.*
combined.log
error.log

# ────────────────────────────────────────────────────────────
# Docker — don't commit generated compose overrides
# ────────────────────────────────────────────────────────────
docker-compose.override.yml
.docker/

# ────────────────────────────────────────────────────────────
# Jenkins — local workspace data
# ────────────────────────────────────────────────────────────
jenkins-data/
.jenkins/

# ────────────────────────────────────────────────────────────
# SonarQube — scanner cache
# ────────────────────────────────────────────────────────────
.sonar/
.scannerwork/

# ────────────────────────────────────────────────────────────
# MongoDB — local data dir (if mounted locally)
# ────────────────────────────────────────────────────────────
mongo-data/
data/db/

# ────────────────────────────────────────────────────────────
# Nexus / Grafana — persisted volume data
# ────────────────────────────────────────────────────────────
nexus-data/
grafana-data/
sonar-data/

# ────────────────────────────────────────────────────────────
# VS Code
# ────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# ────────────────────────────────────────────────────────────
# JetBrains IDEs (WebStorm, IntelliJ)
# ────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws

# ────────────────────────────────────────────────────────────
# Windows OS artifacts
# ────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ────────────────────────────────────────────────────────────
# macOS artifacts (if collaborating cross-platform)
# ────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ────────────────────────────────────────────────────────────
# Wrangler / Cloudflare Pages (Frontend deploy)
# ────────────────────────────────────────────────────────────
.wrangler/
.cloudflare/

# ────────────────────────────────────────────────────────────
# Misc
# ────────────────────────────────────────────────────────────
*.bak
*.swp
*.tmp
*.orig
