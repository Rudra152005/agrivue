pipeline {
    agent any

    environment {
        DOCKER_REGISTRY = "nexus:8082"
        SONAR_TOKEN = credentials('sonarqube-token')
        DOCKER_HUB_CREDENTIALS = credentials('docker-hub-creds')
    }

    stages {
        stage('GitHub Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/Rudra152005/agrivue.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('Frontend') {
                    bat 'npm install'
                }
                dir('backend') {
                    bat 'npm install'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('backend') {
                    bat 'npm test -- --watchAll=false'
                }
                dir('Frontend') {
                    bat 'npm run lint'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'SonarQubeScanner'
                    withSonarQubeEnv('SonarQubeServer') {
                        bat "${scannerHome}\\bin\\sonar-scanner.bat"
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 1, unit: 'HOURS') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                bat 'docker build -t frontend:latest ./devops/docker/frontend'
                bat 'docker build -t backend:latest ./devops/docker/backend'
            }
        }

        stage('Push Images') {
            steps {
                echo 'Skipping image push — configure DOCKER_REGISTRY to enable'
                // bat 'docker tag frontend:latest %DOCKER_REGISTRY%/frontend:latest'
                // bat 'docker push %DOCKER_REGISTRY%/frontend:latest'
            }
        }

        stage('Deploy Containers') {
            steps {
                bat 'docker-compose -f devops/docker-compose.yml up -d'
            }
        }

        stage('Health Check') {
            steps {
                script {
                    def status = bat(script: 'curl -s -o NUL -w "%%{http_code}" http://localhost:80', returnStdout: true).trim()
                    if (status != '200') {
                        error "Health check failed with status ${status}"
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Deployment failed!'
        }
    }
}

