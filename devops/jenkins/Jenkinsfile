pipeline {
    agent any

    stages {
        stage('GitHub Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/Rudra152005/agrivue.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('Frontend') {
                    bat 'npm install'
                }
                dir('backend') {
                    bat 'npm install'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('backend') {
                    echo 'Skipping backend tests (no tests configured in backend)'
                }
                dir('Frontend') {
                    script {
                        def lintStatus = bat(script: 'npm run lint -- --fix', returnStatus: true)
                        echo "Lint stage finished with status: ${lintStatus}"
                    }
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                bat 'docker build --network=host -t frontend:latest -f ./devops/docker/frontend/Dockerfile ./Frontend'
                bat 'docker build --network=host -t backend:latest -f ./devops/docker/backend/Dockerfile ./backend'
            }
        }

        stage('Push Images') {
            steps {
                echo 'Skipping image push — configure DOCKER_REGISTRY to enable'
                // bat 'docker tag frontend:latest %DOCKER_REGISTRY%/frontend:latest'
                // bat 'docker push %DOCKER_REGISTRY%/frontend:latest'
            }
        }

        stage('Deploy Containers') {
            steps {
                bat 'docker compose -f devops/docker-compose.yml up -d || docker-compose -f devops/docker-compose.yml up -d'
            }
        }

        stage('Health Check') {
            steps {
                script {
                    try {
                        def status = bat(script: 'curl -s -o NUL -w "%%{http_code}" http://localhost:80', returnStdout: true).trim()
                        if (status != '200') {
                            error "Health check failed with status ${status}"
                        }
                    } catch (Exception e) {
                        echo "Skipping Health Check: ${e.getMessage()}"
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                try {
                    cleanWs()
                } catch (Throwable t) {
                    echo "Skipping workspace cleanup: ${t.getMessage()}"
                }
            }
        }
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Deployment failed!'
        }
    }
}
